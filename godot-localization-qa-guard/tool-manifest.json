{
  "schema_version": "1.0",
  "name": "godot-localization-qa-guard",
  "entrypoint": "godot-l10n-guard",
  "module": "python -m godot_l10n_guard",
  "interfaces": {
    "cli": true,
    "machine_output": ["json", "sarif"],
    "human_output": ["text", "markdown report"],
    "pseudo_localization_output": true,
    "stress_pack_output": ["pseudo CSV", "long CSV", "compact CSV", "rtl-like CSV", "manifest JSON"],
    "capture_plan_output": ["json", "markdown", "text"],
    "layout_risk_checks": ["string_expansion", "glyph_allow_list"],
    "report_metadata": true,
    "plain_language_rule_help": true,
    "visual_interface": "pseudo-localized CSV preview"
  },
  "run_behavior": {
    "noninteractive": true,
    "safe_on_private_projects": true,
    "network_required": false,
    "writes_only_when_requested": true,
    "exit_codes": {
      "0": "no findings at selected fail threshold, or --fail-on none",
      "1": "findings met selected fail threshold",
      "2": "CLI or argument error"
    }
  },
  "recommended_commands": [
    {
      "purpose": "Script-friendly localization report",
      "command": "godot-l10n-guard <project> --translations translations --scan-scripts --scan-scenes --format json --output localization-report.json --fail-on none"
    },
    {
      "purpose": "Release markdown report",
      "command": "godot-l10n-guard <project> --translations translations --require fr,es,de --format markdown --output docs/LOCALIZATION_QA.md"
    },
    {
      "purpose": "GitHub code scanning SARIF",
      "command": "godot-l10n-guard <project> --translations translations --scan-scripts --scan-scenes --format sarif --output localization-report.sarif --fail-on none"
    },
    {
      "purpose": "Layout-risk and glyph coverage report",
      "command": "godot-l10n-guard <project> --translations translations --max-expansion 1.35 --allowed-glyphs-file fonts/ui-glyphs.txt --format json --output localization-layout.json"
    },
    {
      "purpose": "Pseudo-localized CSV preview",
      "command": "godot-l10n-guard <project> --translations translations --pseudo-output reports/pseudo-localized.csv --fail-on none"
    },
    {
      "purpose": "Localization stress pack for downstream UI layout checks",
      "command": "godot-l10n-guard stress-pack <project> --translations translations --output-dir reports/localization-stress --format markdown --output reports/localization-stress.md"
    },
    {
      "purpose": "Localization screenshot capture plan",
      "command": "godot-l10n-guard capture-plan <project> --stress-pack reports/localization-stress/stress-pack-manifest.json --screen main_menu --screen settings --viewport portrait_phone --format markdown --output reports/localization-capture-plan.md"
    }
  ]
}
