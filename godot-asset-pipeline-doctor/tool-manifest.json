{
  "schema_version": "1.0",
  "name": "godot-asset-pipeline-doctor",
  "entrypoint": "godot-asset-doctor",
  "module": "python -m godot_asset_doctor",
  "interfaces": {
    "cli": true,
    "machine_output": ["json", "sarif"],
    "human_output": ["text", "markdown docs"],
    "report_metadata": true,
    "plain_language_rule_help": true,
    "asset_types": ["png", "wav", "ogg", "mp3"],
    "profiles": ["default", "pixel-2d", "android-mobile", "audio-mobile"],
    "visual_interface": "sprite manifest contact sheets"
  },
  "run_behavior": {
    "noninteractive": true,
    "safe_on_private_projects": true,
    "network_required": false,
    "writes_only_when_requested": true,
    "exit_codes": {
      "0": "no findings at selected fail threshold, or --fail-on none",
      "1": "findings met selected fail threshold",
      "2": "CLI or argument error"
    }
  },
  "recommended_commands": [
    {
      "purpose": "Script-friendly JSON audit",
      "command": "godot-asset-doctor <project> --profile android-mobile --format json --output asset-report.json --fail-on none"
    },
    {
      "purpose": "Audio budget audit",
      "command": "godot-asset-doctor <project> --profile audio-mobile --format json --output audio-asset-report.json --fail-on none"
    },
    {
      "purpose": "Strict CI gate",
      "command": "godot-asset-doctor <project> --profile pixel-2d --fail-on warning"
    },
    {
      "purpose": "GitHub code scanning SARIF",
      "command": "godot-asset-doctor <project> --profile pixel-2d --format sarif --output asset-report.sarif --fail-on none"
    },
    {
      "purpose": "Validate sprite manifest dimensions and anchors",
      "command": "godot-asset-doctor manifest check sprite-manifest.json --project <project> --format json --output reports/sprite-manifest.json"
    },
    {
      "purpose": "Render sprite manifest contact sheet",
      "command": "godot-asset-doctor manifest contact-sheet sprite-manifest.json --project <project> --output reports/sprite-contact-sheet.png"
    }
  ]
}
