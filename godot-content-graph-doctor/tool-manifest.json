{
  "schema_version": "1.0",
  "name": "godot-content-graph-doctor",
  "entrypoint": "godot-content-graph",
  "module": "python -m godot_content_graph_doctor",
  "interfaces": {
    "cli": true,
    "machine_output": ["json"],
    "human_output": ["text", "markdown", "mermaid"],
    "visual_interface": "Mermaid graph text"
  },
  "run_behavior": {
    "noninteractive": true,
    "safe_on_private_projects": true,
    "network_required": false,
    "writes_only_when_requested": true,
    "exit_codes": {
      "0": "no findings at selected fail threshold",
      "1": "findings met selected fail threshold",
      "2": "CLI or argument error"
    }
  },
  "recommended_commands": [
    {
      "purpose": "List built-in content graph presets",
      "command": "godot-content-graph <project> --list-presets"
    },
    {
      "purpose": "Validate a common item and recipe graph without writing config",
      "command": "godot-content-graph <project> --preset recipes --format json --output reports/content-graph.json"
    },
    {
      "purpose": "Show PR impact for changed content files",
      "command": "godot-content-graph <project> --preset recipes --changed-file data/items.json --format markdown"
    },
    {
      "purpose": "Validate content ids and references",
      "command": "godot-content-graph <project> --config content-graph.toml --format json --output reports/content-graph.json"
    },
    {
      "purpose": "Generate a Mermaid dependency graph",
      "command": "godot-content-graph <project> --config content-graph.toml --format mermaid --output reports/content-graph.mmd --fail-on none"
    }
  ]
}
