{
  "schema_version": "1.0",
  "name": "godot-visual-smoke-test-kit",
  "entrypoint": "godot-visual-smoke",
  "module": "python -m godot_visual_smoke",
  "interfaces": {
    "cli": true,
    "machine_output": ["json"],
    "human_output": ["text", "PNG diff images"],
    "viewport_manifest_config": true,
    "visual_interface": "PNG baselines, current captures, and diff images"
  },
  "run_behavior": {
    "noninteractive": true,
    "safe_on_private_projects": true,
    "network_required": false,
    "writes_only_when_requested": true,
    "exit_codes": {
      "0": "visual diff passed, approval succeeded, or --fail-on none",
      "1": "visual diff exceeded threshold",
      "2": "CLI or argument error"
    }
  },
  "recommended_commands": [
    {
      "purpose": "Script-friendly capture plan",
      "command": "godot-visual-smoke plan visual-smoke.toml --project <project> --format json"
    },
    {
      "purpose": "Capture plan with reusable viewport definitions",
      "command": "godot-visual-smoke plan visual-smoke.toml --project <project> --viewport-manifest viewports.toml --format json"
    },
    {
      "purpose": "Script-friendly screenshot comparison",
      "command": "godot-visual-smoke compare <baseline.png> <current.png> --diff <diff.png> --format json --output visual-report.json --fail-on none"
    }
  ]
}
