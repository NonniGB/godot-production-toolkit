{
  "schema_version": "1.0",
  "name": "godot-runtime-telemetry-lab",
  "entrypoint": "godot-telemetry-lab",
  "module": "python -m godot_runtime_telemetry_lab",
  "interfaces": {
    "cli": true,
    "machine_output": ["json"],
    "human_output": ["text", "markdown", "html", "svg"]
  },
  "run_behavior": {
    "noninteractive": true,
    "safe_on_private_projects": true,
    "network_required": false,
    "writes_only_when_requested": true,
    "exit_codes": {
      "0": "no findings at selected fail threshold",
      "1": "findings met selected fail threshold",
      "2": "CLI or argument error"
    }
  },
  "recommended_commands": [
    {
      "purpose": "Summarize runtime telemetry",
      "command": "godot-telemetry-lab summarize reports/runtime --format markdown"
    },
    {
      "purpose": "Compare runtime telemetry with a baseline",
      "command": "godot-telemetry-lab compare reports/baseline reports/current --format json"
    },
    {
      "purpose": "Render a runtime timeline report",
      "command": "godot-telemetry-lab timeline reports/runtime --format html --output reports/runtime-timeline.html"
    },
    {
      "purpose": "Create a reusable runtime budget",
      "command": "godot-telemetry-lab budget init --profile android-high --output reports/runtime-budget.json"
    }
  ]
}
